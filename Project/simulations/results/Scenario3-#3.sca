config image-path ../../../veins/images
config description "Obstacle Shadowing (Buildings block signals)"
config *.annotations.draw true
config *.obstacles.obstacles "xmldoc(\"config_3.xml\", \"//AnalogueModel[@type='SimpleObstacleShadowing']/obstacles\")"
config *.**.nic.phy80211p.decider "xmldoc(\"config_3.xml\")"
config *.**.nic.phy80211p.analogueModels "xmldoc(\"config_3.xml\")"
config repeat 10
config seed-set 3
config network org.car2x.veins.nodes.Scenario
config sim-time-limit 100s
config *.playgroundSizeX 600m
config *.playgroundSizeY 600m
config *.playgroundSizeZ 50m
config *.manager.updateInterval 0.1s
config *.manager.host "\"localhost\""
config *.manager.port 9999
config *.manager.autoShutdown true
config *.manager.launchConfig "xmldoc(\"simulation.launchd.xml\")"
config *.node[*].veinsmobility.x 0
config *.node[*].veinsmobility.y 0
config *.node[*].veinsmobility.z 1.895
config *.node[*].applType "\"TraCIDemo11p\""
