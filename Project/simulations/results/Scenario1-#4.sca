attr network org.car2x.veins.nodes.Scenario
attr processid 4475
attr repetition 4
attr replication #4
attr resultdir results
attr runnumber 4
attr seedset 4
config image-path ../../../veins/images
config description "Pure Free Space (No ground, no buildings)"
config *.annotations.draw false
config *.**.nic.phy80211p.decider "xmldoc(\"config_1.xml\")"
config *.**.nic.phy80211p.analogueModels "xmldoc(\"config_1.xml\")"
config repeat 10
config seed-set 4
config network org.car2x.veins.nodes.Scenario
config sim-time-limit 100s
config *.playgroundSizeX 600m
config *.playgroundSizeY 600m
config *.playgroundSizeZ 50m
config *.manager.updateInterval 0.1s
config *.manager.host "\"localhost\""
config *.manager.port 9999
config *.manager.autoShutdown true
config *.manager.launchConfig "xmldoc(\"simulation.launchd.xml\")"
config *.node[*].veinsmobility.x 0
config *.node[*].veinsmobility.y 0
config *.node[*].veinsmobility.z 1.895
config *.node[*].applType "\"TraCIDemo11p\""
config *.node[*].appl.headerLength "80 bit"
config *.node[*].appl.sendBeacons true
config *.node[*].appl.dataOnSch false
config *.node[*].appl.beaconInterval 0.1s
config *.connectionManager.sendDirect true
config *.connectionManager.maxInterfDist 500m
config *.connectionManager.drawMaxIntfDist false
config *.**.nic.mac1609_4.useServiceChannel false
config *.**.nic.mac1609_4.txPower 20mW
config *.**.nic.mac1609_4.bitrate 6Mbps
config *.**.nic.phy80211p.minPowerLevel -110dBm
config *.**.nic.phy80211p.useNoiseFloor true
