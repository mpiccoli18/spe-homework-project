config *.**.nic.phy80211p.usePropagationDelay true
config **.vector-recording true
config **.scalar-recording true
config *.**.nic.phy80211p.*.vector-recording true
config *.**.nic.mac1609_4.*.vector-recording true
config **.rcvdPower:vector.vector-recording true
config **.snir:vector.vector-recording true

