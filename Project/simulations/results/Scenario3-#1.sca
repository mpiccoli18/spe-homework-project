config image-path ../../../veins/images
config description "Obstacle Shadowing (Buildings block signals)"
config *.annotations.draw true
config *.obstacles.obstacles "xmldoc(\"config_3.xml\", \"//AnalogueModel[@type='SimpleObstacleShadowing']/obstacles\")"
